package pages

// JournalEntryList is kept as a compatibility component for older call sites.
// The active JE list implementation currently lives in JournalEntryListPage so
// filters, FX labels, actions, and tests share one rendered UI path.
templ JournalEntryList(vm JournalEntryListVM) {
	@JournalEntryListPage(vm)
}
