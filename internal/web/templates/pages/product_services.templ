// 遵循project_guide.md
package pages

import "balanciz/internal/models"
import "balanciz/internal/web/templates/layout"
import "balanciz/internal/web/templates/ui"
import "fmt"

templ ProductServices(vm ProductServicesVM) {
	@layout.Layout(
		"Balanciz - Products & Services",
		ui.SidebarVM{Active: "Products & Services", HasCompany: vm.HasCompany},
		bodyProductServices(vm),
	)
}

templ bodyProductServices(vm ProductServicesVM) {
	<div
		class="max-w-[95%]"
		x-data="{ drawerOpen: false }"
		x-init="drawerOpen = $el.dataset.open === 'true'; if (drawerOpen) { $nextTick(() => { const el = $refs.psDrawer?.querySelector('input:not([readonly]),select,textarea'); if (el) el.focus(); }); }"
		data-open={ ui.BoolStr(vm.DrawerOpen) }
		@keydown.escape.window="if (drawerOpen) drawerOpen = false"
	>
		<div class="flex flex-wrap items-start justify-between gap-4">
			<div class="min-w-0 flex-1">
				<h1 class="text-title font-semibold">Products &amp; Services</h1>
				<p class="mt-2 text-text-muted2">
					Items that appear on invoice and bill lines. Each item links to a revenue account for posting.
				</p>
			</div>
			<div class="shrink-0">
				<a
					href="/products-services?new=1"
					class="inline-block rounded-md bg-primary px-4 py-2 text-body font-semibold text-onPrimary hover:bg-primary-hover"
				>
					New Item
				</a>
			</div>
		</div>

		if vm.Created {
			<div class="mt-4 rounded-md border border-success-border bg-success-soft p-4 text-body text-success-hover">
				Item created.
			</div>
		}
		if vm.Updated {
			<div class="mt-4 rounded-md border border-success-border bg-success-soft p-4 text-body text-success-hover">
				Item updated.
			</div>
		}
		if vm.InactiveOK {
			<div class="mt-4 rounded-md border border-success-border bg-success-soft p-4 text-body text-success-hover">
				Item marked inactive. It will no longer appear when creating new invoice lines.
			</div>
		}
		if vm.OpeningOK {
			<div class="mt-4 rounded-md border border-success-border bg-success-soft p-4 text-body text-success-hover">
				Opening balance recorded.
			</div>
		}
		if vm.AdjustmentOK {
			<div class="mt-4 rounded-md border border-success-border bg-success-soft p-4 text-body text-success-hover">
				Inventory adjustment recorded.
			</div>
		}
		if vm.FormError != "" {
			<div class="mt-4 rounded-md border border-border-danger bg-danger-soft p-4 text-body text-danger-hover">
				{ vm.FormError }
			</div>
		}

		// Filter bar — Search + Type + Status. Mirrors the Customers /
		// Vendors / SO/PO list-page pattern so every list surface looks the same.
		<form method="get" action="/products-services" class="mt-6 rounded-lg border border-border bg-surface p-4">
			<div class="flex flex-wrap items-end gap-3">
				<div class="min-w-[260px] flex-1">
					<label for="ps-filter-q" class={ compactLabelClass() }>Search</label>
					<input id="ps-filter-q" type="text" name="q" value={ vm.FilterQ } placeholder="Name or SKU…" autocomplete="off" class={ listFilterInputClass() }/>
				</div>
				<div class="min-w-[180px]">
					<label for="ps-filter-type" class={ compactLabelClass() }>Type</label>
					<select id="ps-filter-type" name="type" class={ listFilterInputClass() }>
						<option value="" selected?={ vm.FilterType == "" }>All types</option>
						for _, t := range models.AllProductServiceTypes() {
							<option value={ string(t) } selected?={ string(t) == vm.FilterType }>{ models.ProductServiceTypeLabel(t) }</option>
						}
					</select>
				</div>
				<div class="min-w-[160px]">
					<label for="ps-filter-stock" class={ compactLabelClass() }>Stock</label>
					<select id="ps-filter-stock" name="stock" class={ listFilterInputClass() } title="Stock filter applies to inventory items only">
						<option value="" selected?={ vm.FilterStockLevel == "" }>Any stock</option>
						<option value="in_stock" selected?={ vm.FilterStockLevel == "in_stock" }>In stock</option>
						<option value="out_of_stock" selected?={ vm.FilterStockLevel == "out_of_stock" }>Out of stock</option>
					</select>
				</div>
				<div class="min-w-[180px]">
					<label for="ps-filter-status" class={ compactLabelClass() }>Status</label>
					<select id="ps-filter-status" name="status" class={ listFilterInputClass() }>
						<option value="active" selected?={ vm.FilterStatus == "active" }>Active</option>
						<option value="inactive" selected?={ vm.FilterStatus == "inactive" }>{ fmt.Sprintf("Inactive (%d)", vm.InactiveItemCount) }</option>
						<option value="all" selected?={ vm.FilterStatus == "all" }>All</option>
					</select>
				</div>
				<div class="flex items-end gap-2">
					<button type="submit" class="rounded-md bg-primary px-3 py-1.5 text-small font-semibold text-onPrimary hover:bg-primary-hover">Apply Filter</button>
					<a href="/products-services" class="rounded-md border border-border-input px-3 py-1.5 text-small text-text-muted3 hover:bg-background hover:text-text">Reset</a>
				</div>
			</div>
		</form>

		<div class="mt-6 rounded-lg border border-border bg-surface p-6">
			<h2 class="text-section font-semibold text-text">All Items</h2>
			<div class="mt-4 overflow-x-auto">
				<table class="w-full text-left text-body">
					<thead class="text-small uppercase tracking-wider text-text-muted">
						<tr class="border-b border-border">
							<th class="py-3 pr-4">Name</th>
							<th class="py-3 pr-4">SKU</th>
							<th class="py-3 pr-4">Type</th>
							<th class="py-3 pr-4 text-right">Price</th>
							<th class="py-3 pr-4">Revenue Account</th>
							<th class="py-3 pr-4 text-right">Qty on Hand</th>
							<th class="py-3 pr-4 text-right">Avg Cost</th>
							<th class="py-3 pr-4 text-right">Inv. Value</th>
							<th class="py-3 pr-0 text-right">Actions</th>
						</tr>
					</thead>
					<tbody class="text-text">
						for _, item := range vm.Items {
							<tr class={ psRowClass(item) }>
								<td class="py-3 pr-4 font-medium">
									{ item.Name }
									if !item.IsActive {
										<span class="ml-2 text-small text-text-muted">(Inactive)</span>
									}
								</td>
								<td class="py-3 pr-4 text-small text-text-muted2">
									if item.SKU != "" {
										{ item.SKU }
									} else {
										<span class="text-text-muted3">—</span>
									}
								</td>
								<td class="py-3 pr-4">
									{ models.ProductServiceTypeLabel(item.Type) }
									if item.ItemStructureType == models.ItemStructureBundle {
										<span class="ml-1 inline-block rounded px-1.5 py-0.5 text-[10px] font-semibold uppercase bg-primary-soft text-primary">Bundle</span>
									}
								</td>
								<td class="py-3 pr-4 text-right tabular-nums">{ item.DefaultPrice.StringFixed(2) }</td>
								<td class="py-3 pr-4">{ psAccountLabel(item) }</td>
								<td class="py-3 pr-4 text-right tabular-nums">
									if v, ok := vm.Valuations[item.ID]; ok {
										{ v.QuantityOnHand }
									} else if item.Type == models.ProductServiceTypeInventory {
										0
									} else {
										<span class="text-text-muted3">—</span>
									}
								</td>
								<td class="py-3 pr-4 text-right tabular-nums">
									if v, ok := vm.Valuations[item.ID]; ok {
										{ v.AverageCost }
									} else if item.Type == models.ProductServiceTypeInventory {
										0.00
									} else {
										<span class="text-text-muted3">—</span>
									}
								</td>
								<td class="py-3 pr-4 text-right tabular-nums">
									if v, ok := vm.Valuations[item.ID]; ok {
										{ v.InventoryValue }
									} else if item.Type == models.ProductServiceTypeInventory {
										0.00
									} else {
										<span class="text-text-muted3">—</span>
									}
								</td>
								<td class="py-3 pr-0 text-right whitespace-nowrap">
									if item.IsActive {
										<a
											href={ "/products-services?edit=" + Uitoa(item.ID) }
											class="text-small font-medium text-primary hover:text-primary-hover"
										>
											Edit
										</a>
										if item.Type == models.ProductServiceTypeInventory || item.ItemStructureType == models.ItemStructureBundle {
											<span class="inline-block px-1 text-text-muted3">|</span>
											<a
												href={ "/products-services/" + Uitoa(item.ID) + "/ledger" }
												class="text-small font-medium text-text-muted2 hover:text-text"
											>
												View Details
											</a>
										}
										<span class="inline-block px-1 text-text-muted3">|</span>
										<form
											method="post"
											action="/products-services/inactive"
											class="inline"
											onsubmit="return confirm('Mark this item inactive? It will no longer appear on new invoice lines, but history is kept.');"
										>
											<input type="hidden" name="item_id" value={ Uitoa(item.ID) }/>
											<button
												type="submit"
												class="text-small font-medium text-text-muted3 hover:text-text"
											>
												Inactive
											</button>
										</form>
									} else {
										<span class="text-small text-text-muted">—</span>
									}
								</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</div>

		@ui.RightDrawerBackdrop()
		if vm.DrawerMode == "edit" {
			@ui.RightDrawerPanel("psDrawer", "ps-drawer-title", "Edit Item", "Update item details and account mapping.", psEditDrawerForm(vm))
		} else {
			@ui.RightDrawerPanel("psDrawer", "ps-drawer-title", "New Item", "Create a product or service for use on invoice lines.", psCreateDrawerForm(vm))
		}
	</div>
}

// psRowClass styles inactive rows.
func psRowClass(item models.ProductService) string {
	if !item.IsActive {
		return "border-b border-border-subtle bg-background text-text-muted2"
	}
	return "border-b border-border-subtle"
}

// psAccountLabel returns code · name for the revenue account, falling back to the ID.
func psAccountLabel(item models.ProductService) string {
	if item.RevenueAccount.Code != "" {
		return item.RevenueAccount.Code + " · " + item.RevenueAccount.Name
	}
	return Uitoa(item.RevenueAccountID)
}

templ psCreateDrawerForm(vm ProductServicesVM) {
	<form method="post" action="/products-services" class="flex min-h-0 flex-1 flex-col">
		@psFormFields(vm)
		<div class="flex shrink-0 flex-wrap items-center justify-end gap-3 border-t border-border p-4">
			<a
				href="/products-services"
				class="rounded-md border border-border-input px-4 py-2 text-body font-semibold text-text-muted3 hover:bg-background hover:text-text"
			>
				Cancel
			</a>
			@ui.ButtonPrimary("Create Item", "submit", false)
		</div>
	</form>
}

templ psEditDrawerForm(vm ProductServicesVM) {
	<form method="post" action="/products-services/update" class="flex min-h-0 flex-1 flex-col">
		<input type="hidden" name="item_id" value={ Uitoa(vm.EditingID) }/>
		@psFormFields(vm)
		<div class="flex shrink-0 flex-wrap items-center justify-end gap-3 border-t border-border p-4">
			<a
				href="/products-services"
				class="rounded-md border border-border-input px-4 py-2 text-body font-semibold text-text-muted3 hover:bg-background hover:text-text"
			>
				Cancel
			</a>
			@ui.ButtonPrimary("Save changes", "submit", false)
		</div>
	</form>
}

templ psFormFields(vm ProductServicesVM) {
	<div
		class="min-h-0 flex-1 space-y-5 overflow-y-auto p-4"
		x-data={ fmt.Sprintf("{ itemType: '%s', structureType: '%s', compCount: %d }", vm.Type, vm.StructureType, maxInt(len(vm.Components), 1)) }
	>
		// Name
		<div>
			<label class="block text-body font-medium text-text">Name *</label>
			<input
				type="text"
				name="name"
				value={ vm.Name }
				placeholder="e.g. Consulting Services"
				autocomplete="off"
				class={ psInputClass(vm.NameError != "") }
			/>
			if vm.NameError != "" {
				<div class="mt-1 text-body text-danger">{ vm.NameError }</div>
			}
		</div>

		// Type
		<div>
			<label class="block text-body font-medium text-text">Type *</label>
			<select
				name="type"
				x-model="itemType"
				class={ psInputClass(vm.TypeError != "") }
			>
				<option value="">-- Select --</option>
				for _, t := range models.AllProductServiceTypes() {
					<option value={ string(t) } selected?={ string(t) == vm.Type }>{ models.ProductServiceTypeLabel(t) }</option>
				}
			</select>
			if vm.TypeError != "" {
				<div class="mt-1 text-body text-danger">{ vm.TypeError }</div>
			}
		</div>

		// SKU
		<div>
			<label class="block text-body font-medium text-text">SKU <span class="font-normal text-text-muted2">(optional)</span></label>
			<input
				type="text"
				name="sku"
				value={ vm.SKU }
				placeholder="e.g. WIDGET-001"
				autocomplete="off"
				class={ psInputClass(false) }
			/>
		</div>

		// Structure Type (single / bundle) — hidden for service and other_charge types
		<div x-show="itemType !== 'service' && itemType !== 'other_charge'" x-cloak>
			<label class="block text-body font-medium text-text">Structure</label>
			<select
				name="structure_type"
				x-model="structureType"
				class={ psInputClass(false) }
			>
				<option value="single" selected?={ vm.StructureType != "bundle" }>Single Item</option>
				<option value="bundle" selected?={ vm.StructureType == "bundle" }>Bundle / Kit</option>
			</select>
			<p class="mt-1 text-small text-text-muted2">Bundle: a sellable package of inventory items. Inventory is tracked on components.</p>
		</div>

		// Default Price (sell)
		<div>
			<label class="block text-body font-medium text-text">Sell price</label>
			<input
				type="text"
				name="default_price"
				value={ vm.DefaultPrice }
				placeholder="0.00"
				inputmode="decimal"
				autocomplete="off"
				class={ psInputClass(vm.DefaultPriceError != "") }
			/>
			if vm.DefaultPriceError != "" {
				<div class="mt-1 text-body text-danger">{ vm.DefaultPriceError }</div>
			}
			<p class="mt-1 text-small text-text-muted2">Pre-fills the unit price on new invoice lines.</p>
		</div>

		// Purchase Price — inventory only
		<div x-show="itemType === 'inventory'" x-cloak>
			<label class="block text-body font-medium text-text">Purchase price</label>
			<input
				type="text"
				name="purchase_price"
				value={ vm.PurchasePrice }
				placeholder="0.00"
				inputmode="decimal"
				autocomplete="off"
				class={ psInputClass(false) }
			/>
			<p class="mt-1 text-small text-text-muted2">Default cost used for purchase bills.</p>
		</div>

		// Account Code — Revenue for standard items; Expense/COGS for Other Charge items.
		<div>
			<label class="block text-body font-medium text-text">Account Code *</label>
			// Revenue accounts dropdown (shown for all types except other_charge)
			<select
				name="revenue_account_id"
				x-show="itemType !== 'other_charge'"
				:disabled="itemType === 'other_charge'"
				class={ psInputClass(vm.RevenueAccountIDError != "") }
			>
				<option value="">-- Select --</option>
				for _, a := range vm.RevenueAccounts {
					<option value={ Uitoa(a.ID) } selected?={ Uitoa(a.ID) == vm.RevenueAccountID }>{ a.Code + " · " + a.Name }</option>
				}
			</select>
			// Expense / COGS accounts dropdown (shown for other_charge only)
			<select
				name="revenue_account_id"
				x-show="itemType === 'other_charge'"
				:disabled="itemType !== 'other_charge'"
				class={ psInputClass(vm.RevenueAccountIDError != "") }
			>
				<option value="">-- Select --</option>
				for _, a := range vm.OtherChargeAccounts {
					<option value={ Uitoa(a.ID) } selected?={ Uitoa(a.ID) == vm.RevenueAccountID }>{ a.Code + " · " + a.Name }</option>
				}
			</select>
			if vm.RevenueAccountIDError != "" {
				<div class="mt-1 text-body text-danger">{ vm.RevenueAccountIDError }</div>
			}
			<p class="mt-1 text-small text-text-muted2" x-show="itemType !== 'other_charge'">The account credited when an invoice line using this item is posted.</p>
			<p class="mt-1 text-small text-text-muted2" x-show="itemType === 'other_charge'">The expense or cost account debited when a negative Other Charge line is posted.</p>
		</div>

		// COGS Account — inventory only
		<div x-show="itemType === 'inventory'" x-cloak>
			<label class="block text-body font-medium text-text">Cost of goods sold account *</label>
			<select
				name="cogs_account_id"
				class={ psInputClass(vm.COGSAccountIDError != "") }
			>
				<option value="">-- Select --</option>
				for _, a := range vm.COGSAccounts {
					<option value={ Uitoa(a.ID) } selected?={ Uitoa(a.ID) == vm.COGSAccountID }>{ a.Code + " · " + a.Name }</option>
				}
			</select>
			if vm.COGSAccountIDError != "" {
				<div class="mt-1 text-body text-danger">{ vm.COGSAccountIDError }</div>
			}
		</div>

		// Inventory Account — inventory only
		<div x-show="itemType === 'inventory'" x-cloak>
			<label class="block text-body font-medium text-text">Inventory asset account *</label>
			<select
				name="inventory_account_id"
				class={ psInputClass(vm.InventoryAccountIDError != "") }
			>
				<option value="">-- Select --</option>
				for _, a := range vm.InventoryAccounts {
					<option value={ Uitoa(a.ID) } selected?={ Uitoa(a.ID) == vm.InventoryAccountID }>{ a.Code + " · " + a.Name }</option>
				}
			</select>
			if vm.InventoryAccountIDError != "" {
				<div class="mt-1 text-body text-danger">{ vm.InventoryAccountIDError }</div>
			}
		</div>

		// Default Tax Code (optional)
		<div>
			<label class="block text-body font-medium text-text">Default tax code <span class="font-normal text-text-muted2">(optional)</span></label>
			<select
				name="default_tax_code_id"
				class={ psInputClass(false) }
			>
				<option value="">-- None --</option>
				for _, tc := range vm.TaxCodes {
					<option value={ Uitoa(tc.ID) } selected?={ Uitoa(tc.ID) == vm.DefaultTaxCodeID }>{ tc.Name }</option>
				}
			</select>
			<p class="mt-1 text-small text-text-muted2">Pre-fills the tax code on new invoice lines.</p>
		</div>

		// Description
		<div>
			<label class="block text-body font-medium text-text">Description <span class="font-normal text-text-muted2">(optional)</span></label>
			<textarea
				name="description"
				rows="3"
				placeholder="Brief description shown on invoices."
				class={ psInputClass(false) }
			>{ vm.Description }</textarea>
		</div>

		// ── Bundle components section ─────────────────────────────────────────
		<div x-show="structureType === 'bundle'" x-cloak>
			@psBundleComponentsSection(vm)
		</div>

		// ── Inventory section (edit mode only, inventory type only) ────────────
		if vm.DrawerMode == "edit" {
			<div x-show="itemType === 'inventory' && structureType !== 'bundle'" x-cloak>
				@psInventorySection(vm)
			</div>
			<div x-show="itemType === 'inventory' && structureType !== 'bundle'" x-cloak>
				@psUOMSection(vm)
			</div>
		}
	</div>
}

// psUOMSection — Phase U1 (2026-04-25). UOM (Unit of Measure) management
// for a single inventory item. Renders three rows:
//   1. Stock UOM — read-only display + a small "Change…" link when no
//      on-hand exists (parallels TrackingMode rule).
//   2. Sell UOM + factor.
//   3. Purchase UOM + factor.
// Posts to /products-services/uom (sell + purchase only). Stock UOM
// changes go through /products-services/stock-uom which has its own
// confirm dialog because changing stock unit also resets sell/purchase
// factors.
templ psUOMSection(vm ProductServicesVM) {
	<div class="border-t border-border pt-4 space-y-4">
		<p class="text-small font-semibold uppercase tracking-wider text-text-muted">
			Units of Measure
		</p>

		if vm.UOMOK {
			<div class="rounded-md border border-success-border bg-success-soft px-3 py-2 text-small text-success-hover">
				UOM updated.
			</div>
		}
		if vm.UOMError != "" {
			<div class="rounded-md border border-border-danger bg-danger-soft px-3 py-2 text-small text-danger-hover">
				{ vm.UOMError }
			</div>
		}

		// ── Stock UOM (read-only with optional change link) ───────────────
		<div class="rounded-md border border-border bg-background p-3">
			<div class="flex items-center justify-between gap-3">
				<div>
					<p class="text-small text-text-muted2">Stock UOM</p>
					<p class="mt-0.5 text-body font-semibold text-text">{ vm.StockUOM }</p>
				</div>
				if vm.UOMHasStock {
					<span class="text-small text-text-muted3" title="Drain on-hand to zero before changing the stock unit.">
						Locked (on-hand &gt; 0)
					</span>
				} else {
					<form
						method="post"
						action="/products-services/stock-uom"
						class="flex items-center gap-2"
						onsubmit="return confirm('Change Stock UOM? This resets Sell + Purchase UOMs to match the new stock unit; you will need to re-enter their factors.');"
					>
						<input type="hidden" name="item_id" value={ Uitoa(vm.EditingID) }/>
						<input
							type="text"
							name="stock_uom"
							value={ vm.StockUOM }
							maxlength="16"
							class="w-20 rounded border border-border-input bg-surface px-2 py-1 text-right text-small font-mono uppercase text-text focus:outline-none focus:ring-2 focus:ring-primary-focus"
						/>
						<button
							type="submit"
							class="rounded-md border border-border-input px-2 py-1 text-[11px] font-medium text-text-muted2 hover:bg-background hover:text-text"
						>Change</button>
					</form>
				}
			</div>
			<p class="mt-1 text-[11px] text-text-muted3">
				The unit inventory + costing counts in. Immutable while on-hand &gt; 0.
			</p>
		</div>

		// ── Sell + Purchase UOMs (edit form) ──────────────────────────────
		<form method="post" action="/products-services/uom" class="rounded-md border border-border bg-background p-3 space-y-3">
			<input type="hidden" name="item_id" value={ Uitoa(vm.EditingID) }/>

			<div class="grid grid-cols-2 gap-3">
				<div>
					<label class="block text-small text-text-muted2">Sell UOM</label>
					<input
						type="text"
						name="sell_uom"
						value={ vm.SellUOM }
						maxlength="16"
						class={ psInputClass(false) + " uppercase" }
					/>
				</div>
				<div>
					<label class="block text-small text-text-muted2">Sell factor (per Stock UOM)</label>
					<input
						type="text"
						inputmode="decimal"
						name="sell_uom_factor"
						value={ vm.SellUOMFactor }
						class={ psInputClass(false) }
					/>
				</div>
			</div>

			<div class="grid grid-cols-2 gap-3">
				<div>
					<label class="block text-small text-text-muted2">Purchase UOM</label>
					<input
						type="text"
						name="purchase_uom"
						value={ vm.PurchaseUOM }
						maxlength="16"
						class={ psInputClass(false) + " uppercase" }
					/>
				</div>
				<div>
					<label class="block text-small text-text-muted2">Purchase factor (per Stock UOM)</label>
					<input
						type="text"
						inputmode="decimal"
						name="purchase_uom_factor"
						value={ vm.PurchaseUOMFactor }
						class={ psInputClass(false) }
					/>
				</div>
			</div>

			<p class="text-[11px] text-text-muted3">
				Factor = how many <span class="font-semibold">{ vm.StockUOM }</span> equal one of this UOM.
				Set to 1 when the UOM matches the stock unit (e.g. sell in BOTTLE, stock in BOTTLE).
			</p>

			<button
				type="submit"
				class="rounded-md bg-primary px-3 py-1.5 text-small font-semibold text-onPrimary hover:bg-primary-hover"
			>Save UOMs</button>
		</form>
	</div>
}

templ psInventorySection(vm ProductServicesVM) {
	<div class="border-t border-border pt-4 space-y-4">
		<p class="text-small font-semibold uppercase tracking-wider text-text-muted">Inventory</p>

		// Current qty on hand (read-only)
		<div>
			<label class="block text-body font-medium text-text">Quantity on hand</label>
			<p class="mt-1 text-body font-semibold text-text tabular-nums">
				if qty, ok := vm.Balances[vm.EditingID]; ok {
					{ qty }
				} else {
					0
				}
			</p>
		</div>

		// Opening balance mini-form
		<div class="rounded-md border border-border bg-background p-3 space-y-3">
			<p class="text-small font-semibold text-text">Record Opening Balance</p>
			<form method="post" action="/products-services/opening" class="space-y-3">
				<input type="hidden" name="item_id" value={ Uitoa(vm.EditingID) }/>
				<div class="grid grid-cols-3 gap-3">
					<div>
						<label class="block text-small text-text-muted2">Quantity</label>
						<input type="text" name="opening_qty" value="0" inputmode="decimal" class={ psInputClass(false) }/>
					</div>
					<div>
						<label class="block text-small text-text-muted2">Unit cost</label>
						<input type="text" name="opening_cost" value="0.00" inputmode="decimal" class={ psInputClass(false) }/>
					</div>
					<div>
						<label class="block text-small text-text-muted2">As of date</label>
						<input type="date" name="opening_date" class={ psInputClass(false) }/>
					</div>
				</div>
				if len(vm.Warehouses) > 0 {
					<div>
						<label class="block text-small text-text-muted2">Warehouse (optional)</label>
						<select name="warehouse_id" class={ psInputClass(false) }>
							<option value="">— Company default —</option>
							for _, w := range vm.Warehouses {
								<option value={ Uitoa(w.ID) }>{ w.Name } ({ w.Code })</option>
							}
						</select>
					</div>
				}
				<button
					type="submit"
					class="rounded-md bg-primary px-3 py-1.5 text-small font-semibold text-onPrimary hover:bg-primary-hover"
				>
					Record Opening
				</button>
			</form>
		</div>

		// Adjustment mini-form
		<div class="rounded-md border border-border bg-background p-3 space-y-3">
			<p class="text-small font-semibold text-text">Adjust Inventory</p>
			<form method="post" action="/products-services/adjustment" class="space-y-3">
				<input type="hidden" name="item_id" value={ Uitoa(vm.EditingID) }/>
				<div class="grid grid-cols-3 gap-3">
					<div>
						<label class="block text-small text-text-muted2">Qty change (+/-)</label>
						<input type="text" name="adj_qty" value="0" inputmode="decimal" class={ psInputClass(false) }/>
					</div>
					<div>
						<label class="block text-small text-text-muted2">Unit cost (opt.)</label>
						<input type="text" name="adj_cost" placeholder="—" inputmode="decimal" class={ psInputClass(false) }/>
					</div>
					<div>
						<label class="block text-small text-text-muted2">Date</label>
						<input type="date" name="adj_date" class={ psInputClass(false) }/>
					</div>
				</div>
				<div>
					<label class="block text-small text-text-muted2">Note (optional)</label>
					<input type="text" name="adj_note" placeholder="e.g. Physical count correction" class={ psInputClass(false) }/>
				</div>
				if len(vm.Warehouses) > 0 {
					<div>
						<label class="block text-small text-text-muted2">Warehouse (optional)</label>
						<select name="warehouse_id" class={ psInputClass(false) }>
							<option value="">— Company default —</option>
							for _, w := range vm.Warehouses {
								<option value={ Uitoa(w.ID) }>{ w.Name } ({ w.Code })</option>
							}
						</select>
					</div>
				}
				<button
					type="submit"
					class="rounded-md border border-border-input bg-surface px-3 py-1.5 text-small font-semibold text-text hover:bg-background"
				>
					Record Adjustment
				</button>
			</form>
		</div>
	</div>
}

templ psBundleComponentsSection(vm ProductServicesVM) {
	<div class="border-t border-border pt-4 space-y-3">
		<p class="text-small font-semibold uppercase tracking-wider text-text-muted">Bundle Components</p>
		if vm.ComponentError != "" {
			<div class="text-body text-danger">{ vm.ComponentError }</div>
		}
		<p class="text-small text-text-muted2">Select inventory items that make up this bundle. Each component's stock is deducted when the bundle is sold.</p>

		<input type="hidden" name="component_count" :value="compCount"/>

		<template x-for="(_, idx) in Array.from({length: compCount})" :key="idx">
			<div class="flex items-end gap-2 rounded border border-border-subtle bg-background p-2">
				<div class="flex-1">
					<label class="block text-small text-text-muted2">Item</label>
					<select
						:name="'comp_item[' + idx + ']'"
						class="mt-1 block w-full rounded-md border border-border-input bg-surface px-2 py-1.5 text-small outline-none focus:ring-2 focus:ring-primary-focus"
					>
						<option value="">-- Select --</option>
						for _, item := range vm.InventoryItems {
							<option value={ Uitoa(item.ID) }>{ item.Name }</option>
						}
					</select>
				</div>
				<div class="w-24">
					<label class="block text-small text-text-muted2">Qty</label>
					<input
						type="text"
						:name="'comp_qty[' + idx + ']'"
						value="1"
						inputmode="decimal"
						class="mt-1 block w-full rounded-md border border-border-input bg-surface px-2 py-1.5 text-small text-text outline-none focus:ring-2 focus:ring-primary-focus"
					/>
				</div>
				<button
					type="button"
					@click="if (compCount > 1) compCount--"
					class="mb-0.5 text-small text-text-muted3 hover:text-danger"
					title="Remove"
				>
					&times;
				</button>
			</div>
		</template>

		<button
			type="button"
			@click="compCount++"
			class="text-small font-medium text-primary hover:text-primary-hover"
		>
			+ Add Component
		</button>
	</div>
}

func maxInt(a, b int) int {
	if a > b {
		return a
	}
	return b
}

func psInputClass(hasErr bool) string {
	if hasErr {
		return "mt-2 block w-full rounded-md border border-danger bg-surface px-3 py-2 text-body text-text outline-none focus:ring-2 focus:ring-danger-focus"
	}
	return "mt-2 block w-full rounded-md border border-border-input bg-surface px-3 py-2 text-body text-text outline-none focus:ring-2 focus:ring-primary-focus"
}
