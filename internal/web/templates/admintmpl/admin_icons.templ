// KPI storage: 16px, neutral — parent card applies opacity (~0.65) and text-text-muted.
// Arc flags must be explicit (e.g. 0 0 1); "0 110-4" is invalid and can blow up SVG bounds in browsers.
templ adminIconKPIStorage() {
	<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 max-h-4 max-w-4 shrink-0" fill="none" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
		<path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 0 1 0-4h14a2 2 0 0 1 0 4M5 8v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8m-9 4h4"/>
	</svg>
}
